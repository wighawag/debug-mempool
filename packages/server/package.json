{
  "name": "purgatory-core",
  "version": "0.0.6",
  "description": "purgatory server hono app",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "hono": "^4.12.9",
    "named-logs": "^0.4.1",
    "remote-sql": "^0.0.7",
    "viem": "^2.47.6"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.2",
    "@types/node": "^25.5.0",
    "as-soon": "^0.1.5",
    "eip-1193": "^0.6.5",
    "ldenv": "^0.3.16",
    "prettier": "^3.8.1",
    "prool": "^0.2.4",
    "remote-procedure-call": "^0.1.1",
    "remote-sql-libsql": "^0.0.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "build:ts": "tsc --project tsconfig.json",
    "build": "pnpm sql2ts && pnpm js2ts && pnpm css2ts && pnpm build:ts",
    "sql2ts": "node sql2ts.cjs ./src/schema/sql",
    "sql2ts:watch": "pnpm sql2ts && as-soon -w ./src/schema/sql pnpm sql2ts",
    "css2ts": "node css2ts.cjs dashboard",
    "css2ts:watch": "pnpm css2ts && as-soon -w ./src/ui/static pnpm css2ts",
    "js2ts": "node js2ts.cjs htmx.min",
    "js2ts:watch": "pnpm js2ts && as-soon -w ./src/ui/static/*.js pnpm js2ts",
    "dev": "pnpm js2ts && as-soon -w src pnpm build:ts"
  }
}