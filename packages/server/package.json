{
  "name": "template-agnostic-server-app",
  "version": "0.0.0",
  "description": "server app",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "hono": "^4.6.13",
    "named-logs": "^0.3.2",
    "remote-sql": "^0.0.6",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@libsql/client": "^0.15.0",
    "@types/node": "^25.2.0",
    "as-soon": "^0.0.11",
    "eip-1193": "^0.6.5",
    "ldenv": "^0.3.12",
    "prettier": "^3.4.2",
    "prool": "^0.2.2",
    "remote-procedure-call": "^0.1.1",
    "remote-sql-libsql": "^0.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "build:ts": "tsc --project tsconfig.json",
    "build": "pnpm sql2ts && pnpm build:ts",
    "sql2ts": "node sql2ts.cjs ./src/schema/sql",
    "sql2ts:watch": "pnpm sql2ts && as-soon -w ./src/schema/sql pnpm sql2ts",
    "css2ts": "node css2ts.cjs global",
    "css2ts:watch": "pnpm css2ts && as-soon -w ./src/schema/css pnpm css2ts",
    "dev": "as-soon -w src pnpm build:ts"
  }
}