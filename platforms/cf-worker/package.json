{
  "name": "purgatory-cf-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "src",
    "tsconfig.json"
  ],
  "dependencies": {
    "named-logs": "^0.4.1",
    "named-logs-context": "^0.1.1",
    "purgatory-core": "workspace:*",
    "remote-sql-d1": "^0.0.7",
    "workers-logger": "0.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.4",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "ldenv": "^0.3.16",
    "set-defaults": "^0.0.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "wrangler": "^4.77.0"
  },
  "scripts": {
    "prepare": "set-defaults .",
    "deploy:production": "wrangler -e production deploy --minify",
    "dev": "pnpm init-db && wrangler dev --log-level error --port 8545",
    "init-db": "ldenv wrangler d1 execute template-agnostic-db --local --file=node_modules/purgatory-core/src/schema/sql/db.sql",
    "test": "vitest",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  }
}