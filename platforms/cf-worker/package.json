{
  "name": "purgatory-cf-worker",
  "version": "0.0.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "src",
    "tsconfig.json"
  ],
  "dependencies": {
    "named-logs": "^0.3.2",
    "named-logs-context": "^0.1.1",
    "remote-sql-d1": "^0.0.6",
    "workers-logger": "0.2.1",
    "purgatory-app": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.36",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^22.10.2",
    "ldenv": "^0.3.12",
    "set-defaults": "^0.0.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.95.0"
  },
  "scripts": {
    "prepare": "set-defaults .",
    "deploy:production": "wrangler -e production deploy --minify",
    "dev": "pnpm init-db && wrangler dev --log-level error --port 8545",
    "init-db": "ldenv wrangler d1 execute template-agnostic-db --local --file=node_modules/purgatory-app/src/schema/sql/db.sql",
    "test": "vitest",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  }
}