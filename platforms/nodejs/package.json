{
  "name": "purgatory",
  "version": "0.0.7",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "purgatory": "./dist/cli.js"
  },
  "files": [
    "dist",
    "stc",
    ".env.default"
  ],
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@libsql/client": "^0.17.2",
    "commander": "^14.0.3",
    "ldenv": "^0.3.16",
    "named-logs-context": "^0.1.1",
    "purgatory-core": "workspace:*",
    "remote-sql-libsql": "^0.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "as-soon": "^0.1.5",
    "set-defaults": "^0.0.5",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "prepare": "set-defaults .env.default",
    "prepublishOnly": "cp ../../README.md ./ && cp ../../LICENSE ./",
    "dev": "tsx watch src/cli.ts --port 8545 --db sqlite.db",
    "build": "tsc",
    "build:watch": "as-soon -w src tsc"
  }
}