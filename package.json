{
  "name": "purgatory-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "cross-var": "^1.1.0",
    "ldenv": "^0.3.16",
    "zellij-launcher": "^0.0.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepublishOnly": "pnpm -r prepublishOnly",
    "release": "pnpm prepublishOnly && git push --all && pnpm changeset publish && git push --tags",
    "---------------------- FORMAT ----------------------": "",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "---------------------- DEV ----------------------": "",
    "cf-worker:dev": "pnpm --filter purgatory-cf-worker dev",
    "nodejs:dev": "pnpm --filter purgatory-nodejs dev",
    "server:dev": "pnpm --filter purgatory-core dev",
    "---------------------- DEPLOY ----------------------": "",
    "build": "ldenv pnpm run -r build",
    "deploy:cf": "pnpm run --filter purgatory-server-cf-worker deploy",
    "---------------------- RUN FULL LOCAL SETUP ----------------------": "",
    "start:nodejs": "cross-var zellij-launcher a $npm_package_name || cross-var ldenv -d localhost zellij -n zellij-nodejs.kdl -s $npm_package_name",
    "stop": "cross-var zellij kill-session $npm_package_name",
    "start": "cross-var zellij-launcher a $npm_package_name || cross-var ldenv -d localhost zellij -n zellij.kdl -s $npm_package_name"
  }
}
